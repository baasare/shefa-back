# Environment
ENVIRONMENT=development

# Django
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,api.shefafx.com
ALLOWED_HOSTS=shefafx.up.railway.app,www.shefafx.up.railway.app,api.shefafx.com,www.api.shefafx.com,shefafx.com,www.shefafx.com

# Database
POSTGRES_DB_NAME=shefa_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# Frontend
FRONTEND_URL=http://localhost:3000
LANDING_PAGE_URL=https://shefafx.com
APP_URL=https://app.shefafx.com
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://shefafx.com,https://www.shefafx.com,https://app.shefafx.com

# AI/LLM APIs
ANTHROPIC_API_KEY=your-anthropic-api-key

# Market Data APIs
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-key
MASSIVE_API_KEY=your-massive-api-key-formerly-polygon

# Broker APIs (Alpaca)
ALPACA_API_KEY=your-alpaca-key
ALPACA_API_SECRET=your-alpaca-secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Email (for production)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@example.com
EMAIL_HOST_PASSWORD=your-email-password
DEFAULT_FROM_EMAIL=noreply@shefaai.com

# Resend (Primary email service for transactional emails)
RESEND_API_KEY=re_your_resend_api_key_here
RESEND_FROM_EMAIL=noreply@shefaai.com
RESEND_FROM_NAME=ShefaFx Trading

# OAuth (Google)
GOOGLE_OAUTH_CLIENT_ID=your-google-client-id
GOOGLE_OAUTH_CLIENT_SECRET=your-google-client-secret

# Monitoring (optional)
SENTRY_DSN=your-sentry-dsn

ENCRYPTION_KEY=your-encryption-key-here